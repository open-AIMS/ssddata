@article{Stauber2021,
abstract = {There has been an increased emphasis on incorporating bioavailability-based approaches into freshwater guideline value derivations for metals in the Australian and New Zealand water quality guidelines. Four bioavailability models were compared: the existing European biotic ligand model (European Union BLM) and a softwater BLM, together with 2 newly developed multiple linear regressions (MLRs)-a trophic level-specific MLR and a pooled MLR. Each of the 4 models was used to normalize a nickel ecotoxicity dataset (combined tropical and temperate data) to an index condition of pH 7.5, 6 mg Ca/L, 4 mg Mg/L, (i.e., approximately 30 mg CaCO 3 /L hardness), and 0.5 mg DOC/L. The trophic level-specific MLR outperformed the other 3 models, with 79% of the predicted 10% effect concentration (EC10) values within a factor of 2 of the observed EC10 values. All 4 models gave similar normalized species sensitivity distributions and similar estimates of protective concentrations (PCs). Based on the index condition water chemistry proposed as the basis of the national guideline value, a protective concentration for 95% of species (PC95) of 3 µg Ni/L was derived. This guideline value can be adjusted up and down to account for site-specific water chemistries. Predictions of PC95 values for 20 different typical water chemistries for Australia and New Zealand varied by >40-fold, which confirmed that correction for nickel bioavailability is critical for the derivation of site-specific guideline values.},
author = {Stauber, Jenny and Golding, Lisa and Peters, Adam and Merrington, Graham and Adams, Merrin and Binet, Monique and Batley, Graeme and Gissi, Francesca and Mcknight, Kitty and Garman, Emily and Middleton, Ellie and Gadd, Jennifer and Schlekat, Chris},
doi = {10.1002/etc.4885},
journal = {Environmental Toxicology and Chemistry},
keywords = {Biotic ligand model,Metals,Multiple linear regressions,Water quality criteria},
month = {jan},
number = {1},
pages = {100--112},
publisher = {Wiley Blackwell},
title = {{Environmental Toxicology Application of Bioavailability Models to Derive Chronic Guideline Values for Nickel in Freshwaters of Australia and New Zealand}},
url = {https://setac.onlinelibrary.wiley.com/doi/abs/10.1002/etc.4885},
volume = {40},
year = {2021}
}
